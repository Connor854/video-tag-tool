PORT=3001

SUPABASE_URL=your-supabase-url
SUPABASE_ANON_KEY=your-supabase-anon-key

# Client (Vite) — same values as above, required for browser Auth
VITE_SUPABASE_URL=your-supabase-url
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
JINA_API_KEY=your-jina-api-key
ADMIN_SECRET=your-admin-secret

# Optional: fallback workspace when no auth headers (admin secret, <img> requests, scripts).
# Used by: trpc workspace middleware, resolveWorkspace (thumbnail/video routes), scripts via getDefaultWorkspaceId().
# When unset: requests without JWT or admin secret fail with 401. Scripts that need a workspace will throw.
# For multi-tenant production: prefer unset; use JWT + workspace_members. See docs/DEFAULT_WORKSPACE_ID_SEMANTICS.md.
DEFAULT_WORKSPACE_ID=00000000-0000-0000-0000-000000000001

# Shopify OAuth (Phase 2F) — required for Connect Shopify flow
SHOPIFY_CLIENT_ID=your-shopify-client-id
SHOPIFY_CLIENT_SECRET=your-shopify-client-secret
APP_URL=http://localhost:3001
